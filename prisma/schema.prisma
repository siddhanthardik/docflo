generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Doctor {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  password               String
  name                   String
  phone                  String?
  specialty              String?
  clinicName             String?
  address                String?
  city                   String?
  state                  String?
  country                String?
  role                   UserRole                @default(DOCTOR)
  emailVerified          DateTime?
  image                  String?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  daysOff                String[]                @default([])
  timezone               String?                 @default("UTC")
  currency               String?                 @default("USD")
  isCurrencyLocked       Boolean                 @default(false)
  dateFormat             String?                 @default("MM/DD/YYYY")
  firstDayOfWeek         Int?                    @default(0)
  invoiceFooter          String?
  invoicePrefix          String?                 @default("INV-")
  language               String?                 @default("en")
  taxGstNumber           String?
  workingHoursEnd        String?                 @default("17:00")
  workingHoursStart      String?                 @default("09:00")
  subscriptionStatus     SubscriptionStatus      @default(ACTIVE)
  subscriptionExpiry     DateTime?
  billingPeriod          String?                 @default("monthly") // monthly, quarterly, yearly
  isSuspended            Boolean                 @default(false)
  failedLoginAttempts    Int                     @default(0)
  lockedUntil            DateTime?
  stripeCustomerId       String?
  razorpayCustomerId     String?
  razorpaySubscriptionId String?
  packageId              String?
  package                Package?                @relation(fields: [packageId], references: [id])
  gcalAccessToken        String?
  gcalRefreshToken       String?
  gcalCalendarId         String?                 @default("primary")
  gcalConnectedAt        DateTime?
  salesRepId             String? // ID of the SALES user who onboarded this customer
  appointments           Appointment[]
  practitioners          Practitioner[]
  campaigns              Campaign[]
  aiAgentConfigs         AIAgentConfig[]
  featureOverrides       ClinicFeatureOverride[]
  conversations          Conversation[]
  gbpAccounts            GbpAccount[]
  gbpPosts               GBPPost[]
  patients               Patient[]
  reviews                Review[]
  serviceTypes           ServiceType[]
  staffMembers           StaffMember[]
  waitlistEntries        WaitlistEntry[]
  paymentTransactions    PaymentTransaction[]
  invoices               Invoice[]
  auditLead              AuditLead?
  subscriptionHistories  SubscriptionHistory[]

  // Review Automation Settings
  reviewAutomationEnabled       Boolean @default(true)
  reviewCooldownDays            Int     @default(90)
  reviewDelayMinutes            Int     @default(45)
  reviewSurveyMessage           String?
  reviewGoogleInvitationMessage String?

  // Usage tracking
  currentAiCredits Int @default(0)
  currentPatients  Int @default(0)

  @@map("doctors")
}

model Patient {
  id                    String         @id @default(cuid())
  doctorId              String
  firstName             String
  lastName              String
  phone                 String
  email                 String?
  dateOfBirth           DateTime?
  gender                String?
  bloodGroup            String?
  address               String?
  medicalNotes          String?
  tags                  String[]
  patientType           PatientType    @default(LEAD)
  lastReviewRequestedAt DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  gbpAccountId          String?
  primaryPractitionerId String?
  appointments          Appointment[]
  conversations         Conversation[]
  invoices              Invoice[]
  doctor                Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount            GbpAccount?    @relation(fields: [gbpAccountId], references: [id])
  primaryPractitioner   Practitioner?  @relation(fields: [primaryPractitionerId], references: [id])

  @@index([doctorId])
  @@index([doctorId, createdAt])
  @@index([gbpAccountId])
  @@map("patients")
}

model Practitioner {
  id                 String   @id @default(cuid())
  doctorId           String
  name               String
  email              String?
  phone              String?
  specialty          String?
  otherSpecialty     String?
  qualification      String?
  registrationNumber String?
  consultationFee    Float?
  duration           Int?
  bufferTime         Int?
  isOwner            Boolean  @default(false)
  isActive           Boolean  @default(true)
  calendarColor      String?  @default("#4F46E5")
  displayOrder       Int      @default(0)
  workingDays        String[] @default([])
  workingHoursEnd    String?  @default("17:00")
  workingHoursStart  String?  @default("09:00")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  doctor       Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  patients     Patient[]

  @@index([doctorId])
  @@map("practitioners")
}

model Appointment {
  id              String                  @id @default(cuid())
  patientId       String
  doctorId        String
  date            DateTime
  startTime       DateTime
  endTime         DateTime
  reason          String?
  status          AppointmentStatus       @default(CONFIRMED)
  notes           String?
  reminderSent    Boolean                 @default(false)
  reviewRequested Boolean                 @default(false) // LEGACY: Keep for migration
  reviewStatus    AppointmentReviewStatus @default(NOT_SENT)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  gbpAccountId    String?
  practitionerId  String?
  gcalEventId     String?
  doctor          Doctor                  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount      GbpAccount?             @relation(fields: [gbpAccountId], references: [id])
  practitioner    Practitioner?           @relation(fields: [practitionerId], references: [id])
  patient         Patient                 @relation(fields: [patientId], references: [id], onDelete: Cascade)
  followUps       AppointmentFollowUp[]
  invoices        Invoice[]

  @@index([doctorId, date])
  @@index([patientId])
  @@index([gbpAccountId])
  @@index([practitionerId])
  @@map("appointments")
}

model AppointmentFollowUp {
  id            String   @id @default(cuid())
  appointmentId String
  type          String // e.g., "1_DAY", "1_WEEK", "POST_OP"
  sentAt        DateTime @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId])
  @@map("appointment_follow_ups")
}

model GbpAccount {
  id                      String                   @id @default(cuid())
  doctorId                String
  accessToken             String
  refreshToken            String
  tokenExpiry             DateTime
  locationId              String?
  locationName            String?
  insightsData            Json?
  lastSyncAt              DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  appointments            Appointment[]
  campaigns               Campaign[]
  doctor                  Doctor                   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpPosts                GBPPost[]
  patients                Patient[]
  reviews                 Review[]
  waitlist                WaitlistEntry[]
  profileSnapshots        ProfileSnapshot[]
  gbpPerformanceSnapshots GbpPerformanceSnapshot[]
  gbpKeywordSnapshots     GbpKeywordSnapshot[]
  gbpReviewSnapshots      GbpReviewSnapshot[]
  competitorSnapshots     CompetitorSnapshot[]
  gbpPostSnapshots        GbpPostSnapshot[]
  gbpQaSnapshots          GbpQaSnapshot[]
  searchGridSnapshots     SearchGridSnapshot[]
  seoRecommendations      SeoRecommendation[]

  @@unique([doctorId, locationName])
  @@map("gbp_accounts")
}

model Review {
  id           String       @id @default(cuid())
  doctorId     String
  reviewerName String
  rating       Int
  comment      String?
  reply        String?
  source       ReviewSource @default(GOOGLE)
  reviewDate   DateTime
  responded    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  gbpAccountId String?
  doctor       Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount   GbpAccount?  @relation(fields: [gbpAccountId], references: [id])

  @@index([doctorId])
  @@index([doctorId, reviewDate])
  @@index([gbpAccountId])
  @@map("reviews")
}

model WhatsAppTemplate {
  id         String   @id @default(cuid())
  doctorId   String
  name       String
  language   String   @default("en")
  category   String
  components Json
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([doctorId, name])
  @@map("whatsapp_templates")
}

model WhatsAppMessage {
  id           String    @id @default(cuid())
  doctorId     String
  patientPhone String
  patientName  String?
  templateName String?
  messageType  String
  content      Json
  status       String    @default("SENT")
  deliveredAt  DateTime?
  readAt       DateTime?
  createdAt    DateTime  @default(now())

  @@index([doctorId, patientPhone])
  @@map("whatsapp_messages")
}

model StaffMember {
  id                  String         @id @default(cuid())
  doctorId            String
  email               String         @unique
  password            String
  name                String
  role                StaffRole      @default(RECEPTIONIST)
  phone               String?
  isActive            Boolean        @default(true)
  emailVerified       DateTime?
  failedLoginAttempts Int            @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  assignedChats       Conversation[]
  doctor              Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("staff_members")
}

model Conversation {
  id            String        @id @default(cuid())
  doctorId      String
  patientPhone  String
  patientName   String?
  patientId     String?
  status        ChatStatus    @default(OPEN)
  assignedToId  String?
  lastMessageAt DateTime      @default(now())
  unreadCount   Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  messages      ChatMessage[]
  assignedTo    StaffMember?  @relation(fields: [assignedToId], references: [id])
  doctor        Doctor        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient       Patient?      @relation(fields: [patientId], references: [id])

  @@unique([doctorId, patientPhone])
  @@map("conversations")
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  messageType    String           @default("text")
  content        String
  mediaUrl       String?
  senderName     String?
  createdAt      DateTime         @default(now())
  readAt         DateTime?
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model ServiceType {
  id          String   @id @default(cuid())
  doctorId    String
  name        String
  duration    Int
  price       Float?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@map("service_types")
}

model WaitlistEntry {
  id                     String         @id @default(cuid())
  doctorId               String
  patientId              String?
  patientName            String
  patientPhone           String
  serviceType            String?
  preferredDate          DateTime?
  priority               Int            @default(0)
  status                 WaitlistStatus @default(WAITING)
  notifiedAt             DateTime?
  convertedAppointmentId String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  gbpAccountId           String?
  doctor                 Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount             GbpAccount?    @relation(fields: [gbpAccountId], references: [id])

  @@index([doctorId])
  @@index([gbpAccountId])
  @@map("waitlist_entries")
}

model GBPPost {
  id           String      @id @default(cuid())
  doctorId     String
  title        String
  content      String
  postType     String
  imageUrl     String?
  ctaType      String?
  ctaLink      String?
  status       PostStatus  @default(DRAFT)
  scheduledFor DateTime?
  publishedAt  DateTime?
  gbpPostId    String?
  metrics      Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  gbpAccountId String?
  doctor       Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount   GbpAccount? @relation(fields: [gbpAccountId], references: [id])

  @@index([doctorId])
  @@index([gbpAccountId])
  @@map("gbp_posts")
}

model Campaign {
  id           String              @id @default(cuid())
  doctorId     String
  name         String
  message      String
  segmentType  String
  segmentValue String?
  status       CampaignStatus      @default(DRAFT)
  mediaUrl     String?
  mediaType    String?             // e.g. "IMAGE", "PDF"
  ctaText      String?
  ctaLink      String?
  scheduledAt  DateTime?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  gbpAccountId String?
  recipients   CampaignRecipient[]
  doctor       Doctor              @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  gbpAccount   GbpAccount?         @relation(fields: [gbpAccountId], references: [id])

  @@index([doctorId])
  @@index([gbpAccountId])
  @@map("campaigns")
}

model CampaignRecipient {
  id           String          @id @default(cuid())
  campaignId   String
  patientId    String?
  patientPhone String
  patientName  String?
  status       RecipientStatus @default(PENDING)
  sentAt       DateTime?
  error        String?
  createdAt    DateTime        @default(now())
  campaign     Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_recipients")
}

model AIAgentConfig {
  id        String   @id @default(cuid())
  doctorId  String
  agentType String // "APPOINTMENT", "REVIEW", "PROFILE", "RANKING"
  enabled   Boolean  @default(false)
  config    Json     @default("{}") // Stores agent-specific settings (tone, constraints, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, agentType])
  @@map("ai_agent_configs")
}

enum UserRole {
  DOCTOR
  ADMIN
  SUPERADMIN
  SALES
  ACCOUNTS
  MARKETING
}

model Package {
  id                  String               @id @default(cuid())
  slug                String?              @unique // Idempotency key; backfilled after initial push
  name                String
  description         String?
  price               Float? // Deprecated: keeping temporarily for migration
  billingPeriod       String? // Deprecated: keeping temporarily for migration
  priceMonthly        Float                @default(0)
  priceQuarterly      Float                @default(0)
  priceYearly         Float                @default(0)
  razorpayPlanId      String? // ID from Razorpay Dashboard
  features            Json                 @default("{}") // Deprecated: keeping temporarily for migration
  packageFeatures     PackageFeature[]
  modules             PackageModule[]
  limits              PackageLimit[]
  isActive            Boolean              @default(true)
  isArchived          Boolean              @default(false) // Soft archive; archived packages cannot be assigned to new doctors
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  doctors             Doctor[]
  paymentTransactions PaymentTransaction[]

  @@map("packages")
}

enum ModuleName {
  CLINIC_CORE
  GROWTH_SEO
  WHATSAPP_CRM
  AI_ASSISTANT
}

enum LimitName {
  MAX_STAFF_SEATS
  MAX_PATIENTS
  MAX_PRACTITIONERS
  MAX_GBP_LOCATIONS
  MAX_TRACKED_KEYWORDS
  MAX_SCHEDULED_POSTS
  AI_CREDITS_PER_MONTH
}

model PackageModule {
  id         String     @id @default(cuid())
  packageId  String
  moduleName ModuleName

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, moduleName])
  @@map("package_modules")
}

model PackageLimit {
  id         String    @id @default(cuid())
  packageId  String
  limitName  LimitName
  limitValue Int? // Null implies Unlimited

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, limitName])
  @@map("package_limits")
}

// Immutable record created every time a doctor's package changes
model SubscriptionHistory {
  id                String   @id @default(cuid())
  doctorId          String
  previousPackageId String?
  newPackageId      String
  changedById       String // ID of the admin/staff who made the change
  changedByRole     String // Role of changer at time of change (SUPERADMIN, ADMIN, etc.)
  reason            String? // Optional reason for the change
  createdAt         DateTime @default(now())

  doctor Doctor @relation(fields: [doctorId], references: [id])

  @@map("subscription_history")
}

model Promotion {
  id              String    @id @default(cuid())
  code            String    @unique
  description     String?
  discountPercent Float
  razorpayOfferId String?
  expiresAt       DateTime?
  usageLimit      Int?
  usageCount      Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("promotions")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReviewSource {
  GOOGLE
  MANUAL
}

enum IntegrationType {
  GOOGLE_BUSINESS
  WHATSAPP
}

enum AppointmentReviewStatus {
  NOT_SENT
  SURVEY_SENT
  POSITIVE_RESPONSE
  NEGATIVE_RESPONSE
  LINK_SENT
}

enum StaffRole {
  RECEPTIONIST
  STAFF
  NURSE
  MANAGER
  ADMIN
}

enum ChatStatus {
  OPEN
  ASSIGNED
  RESOLVED
  CLOSED
}

enum MessageDirection {
  INCOMING
  OUTGOING
  INTERNAL_NOTE
}

enum WaitlistStatus {
  WAITING
  NOTIFIED
  CONFIRMED
  CANCELLED
  EXPIRED
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum RecipientStatus {
  PENDING
  SENT
  FAILED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

model PaymentTransaction {
  id                String   @id @default(cuid())
  doctorId          String
  packageId         String
  amount            Float
  currency          String   @default("USD")
  status            String   @default("SUCCESS") // SUCCESS, FAILED
  razorpayOrderId   String?
  razorpayPaymentId String?
  promoCode         String?
  createdAt         DateTime @default(now())

  doctor  Doctor  @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  package Package @relation(fields: [packageId], references: [id])

  @@map("payment_transactions")
}

enum PatientType {
  LEAD
  ACTIVE
  INACTIVE
  LOST
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String
  doctorId      String
  patientId     String
  appointmentId String?
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  paidAt        DateTime?

  subtotal       Float
  discountType   DiscountType @default(FLAT)
  discountValue  Float        @default(0)
  discountAmount Float        @default(0)
  taxAmount      Float        @default(0)
  totalAmount    Float

  currencyCode   String @default("INR")
  currencySymbol String @default("₹")

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor      Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient     Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment Appointment?     @relation(fields: [appointmentId], references: [id])
  items       InvoiceItem[]
  payments    PatientPayment[]

  @@unique([doctorId, invoiceNumber])
  @@index([doctorId])
  @@index([patientId])
  @@map("invoices")
}

model InvoiceItem {
  id            String   @id @default(cuid())
  invoiceId     String
  serviceTypeId String?
  description   String
  quantity      Int      @default(1)
  unitPrice     Float
  total         Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

model PatientPayment {
  id            String        @id @default(cuid())
  invoiceId     String
  doctorId      String
  amount        Float
  paymentMethod PaymentMethod
  paymentDate   DateTime      @default(now())
  referenceId   String?
  createdAt     DateTime      @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([doctorId])
  @@map("patient_payments")
}

enum InvoiceStatus {
  DRAFT
  UNPAID
  PAID
  PARTIALLY_PAID
  CANCELLED
  OVERDUE
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  BANK_TRANSFER
  OTHER
}

model PlatformLead {
  id         String     @id @default(cuid())
  name       String?
  email      String?
  phone      String?
  clinicName String?
  source     String // e.g. "AUDIT_REPORT", "HOME_PAGE", "CONTACT_US"
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@map("platform_leads")
}

enum LeadStatus {
  NEW
  CONTACTED
  CONVERTED
  LOST
}

// ==========================================
// RBAC & PLATFORM SAAS MODELS
// ==========================================

enum PlatformRole {
  SUPERADMIN
  SUPERVISOR
  SUPPORT
  SALES
  MARKETING
  ACCOUNTS
}

enum ClinicRole {
  DOCTOR
  ADMIN
  STAFF
  RECEPTIONIST
}

model PlatformUser {
  id                  String       @id @default(cuid())
  name                String
  email               String       @unique
  password            String
  role                PlatformRole @default(SUPPORT)
  isActive            Boolean      @default(true)
  emailVerified       DateTime?
  failedLoginAttempts Int          @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  assignedLeads AuditLead[]

  @@map("platform_users")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userType  String // "PLATFORM" or "CLINIC"
  action    String // e.g. "LOGIN", "SUBSCRIPTION_CHANGE"
  details   Json     @default("{}")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@map("email_verification_tokens")
}

// ==========================================
// FEATURE FLAG ENGINE
// ==========================================

model FeatureFlag {
  id           String  @id @default(cuid())
  name         String
  key          String  @unique
  description  String?
  type         String // "BOOLEAN" or "NUMBER"
  defaultValue String // "true", "false", or "10"

  packageFeatures PackageFeature[]
  clinicOverrides ClinicFeatureOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feature_flags")
}

model PackageFeature {
  id        String  @id @default(cuid())
  packageId String
  featureId String
  isEnabled Boolean @default(false)
  limit     Int? // For NUMBER type features

  package Package     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  feature FeatureFlag @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([packageId, featureId])
  @@map("package_features")
}

model ClinicFeatureOverride {
  id        String  @id @default(cuid())
  doctorId  String
  featureId String
  isEnabled Boolean @default(false)

  doctor  Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  feature FeatureFlag @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([doctorId, featureId])
  @@map("clinic_feature_overrides")
}

// ==========================================
// FREE AI LOCAL SEO AUDIT MODELS
// ==========================================

enum AuditLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CUSTOMER
}

model AuditRequest {
  id          String   @id @default(cuid())
  placeId     String?
  searchQuery String
  status      String   @default("PENDING") // PENDING, SCANNING, COMPLETED, FAILED
  progress    Int      @default(0) // 0 to 100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  report AuditReport?

  leadId String?
  lead   AuditLead? @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("audit_requests")
}

model AuditReport {
  id           String  @id @default(cuid())
  requestId    String  @unique
  businessName String
  speciality   String?
  address      String?
  websiteUrl   String?

  // Exact API metrics
  primaryCategory     String?
  secondaryCategories String[] @default([])
  businessType        String?
  rating              Float?
  reviewCount         Int?

  // Version 3 Diagnostic Report Sections (Premium Consultant Framework)
  businessOverview       Json?
  businessSnapshot       Json?
  visibilityIssues       Json?
  competitorIntelligence Json?
  profileCompleteness    Json?
  competitorGapAnalysis  Json?
  healthcareIntelligence Json?
  priorityActionPlan     Json?
  growthOpportunities    Json?
  aiActionPlan           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request         AuditRequest          @relation(fields: [requestId], references: [id], onDelete: Cascade)
  competitors     AuditCompetitor[]
  recommendations AuditRecommendation[]

  @@map("audit_reports")
}

model AuditCompetitor {
  id          String  @id @default(cuid())
  reportId    String
  name        String
  speciality  String? // Used for strictly matching Speciality-to-Speciality
  distance    Float?
  rating      Float?
  reviewCount Int?

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("audit_competitors")
}

model AuditRecommendation {
  id            String  @id @default(cuid())
  reportId      String
  category      String // GBP, WEBSITE, REVIEWS
  title         String
  description   String // AI-driven Action Plan (Locked)
  priority      String // HIGH, MEDIUM, LOW
  impact        Int // 1-10
  currentStatus String?
  estimatedOpp  String? // E.g., "+$5,000/mo"
  aiAutomatable Boolean @default(false)

  report AuditReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("audit_recommendations")
}

model AuditLead {
  id              String  @id @default(cuid())
  legacyRequestId String? @map("requestId")
  name            String
  email           String?
  phone           String?
  clinicName      String?
  placeId         String? // Used for deduplication alongside phone

  status AuditLeadStatus @default(NEW)

  // Marketing & Attribution
  leadSource  String?
  landingPage String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  gclid       String?
  fbclid      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  requests   AuditRequest[]
  activities LeadActivity[]

  assignedToId String?
  assignedTo   PlatformUser? @relation(fields: [assignedToId], references: [id])

  convertedDoctorId String? @unique
  convertedDoctor   Doctor? @relation(fields: [convertedDoctorId], references: [id])

  // Gracefully handle duplicate submissions for the same physical location & phone
  @@unique([phone, placeId])
  @@map("audit_leads")
}

model LeadActivity {
  id        String   @id @default(cuid())
  leadId    String
  eventType String // e.g., "LEAD_CREATED", "AUDIT_STARTED", "AUDIT_COMPLETED", "AUDIT_FAILED", "SALES_CONTACTED"
  message   String
  metadata  Json? // Any contextual metadata (e.g., audit ID, error message)
  createdAt DateTime @default(now())

  lead AuditLead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("lead_activities")
}

